# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-to-a-long-random-secret-in-production

# Token lifetime in minutes (default 8h)
AUTH_TOKEN_EXPIRE_MINUTES=480

# Bootstrap admin account — change immediately after first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * for dev or when behind a reverse proxy on the same host.
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Leave empty to use embedded SQLite.
# PostgreSQL: postgresql://user:pass@host:5432/purpleclaw
DATABASE_URL=

# ── Demo seed data ─────────────────────────────────────────────────────────────
# Set to false to skip demo assets/alerts/findings on first run.
# Only the admin user will be created when false.
SEED_DEMO_DATA=true

# ── Prometheus ─────────────────────────────────────────────────────────────────
# URL of your Prometheus instance.
# Homelab (host services, Docker deployed): http://host.docker.internal:9090
# Same Docker network: http://prometheus:9090
# Remote host: http://192.168.1.x:9090
PROMETHEUS_URL=http://host.docker.internal:9090
PROMETHEUS_ENV_ID=homelab
PROMETHEUS_TIMEOUT=3.0

# Additional Prometheus environments (optional):
# PROMETHEUS_URL_STAGING=http://staging-host:9090

# ── Loki ───────────────────────────────────────────────────────────────────────
# URL of your Loki instance.
LOKI_URL=http://host.docker.internal:3100
LOKI_ENV_ID=homelab
LOKI_TIMEOUT=3.0

# Comma-separated log source names expected in Loki (for gap detection).
# Leave empty to disable gap detection.
LOKI_EXPECTED_SOURCES=auth,syslog,kubernetes

# Additional Loki environments (optional):
# LOKI_URL_STAGING=http://staging-host:3100

# ── Autonomous Engine ──────────────────────────────────────────────────────────
# How often the auto-discovery engine scans for new assets (seconds)
DISCOVERY_INTERVAL=900
# How often the threat detection engine scans for threats (seconds)
THREAT_INTERVAL=300
# Enable automated threat response (false = detect only, true = also take action)
# safe: annotate K8s pods, log recommendations
# aggressive: also execute iptables blocks for external attacker IPs
AUTO_RESPONSE=false
AUTO_RESPONSE_LEVEL=safe

# ── Network Scanner (zero-config discovery) ────────────────────────────────────
# Scans the container's /24 subnet plus host.docker.internal automatically.
# No configuration needed — the scanner fingerprints any open port it finds.
# Set to false to disable and rely only on the explicit URL env vars above.
SCAN_NETWORK=true
# Extra CIDR ranges to scan (comma-separated). Leave empty for auto-detection.
# Example: SCAN_RANGES=192.168.10.0/24,10.0.1.0/24
SCAN_RANGES=
# Ranges to exclude (comma-separated). Useful to skip cloud management IPs.
SCAN_EXCLUDE=
# TCP connect timeout per port (lower = faster scan, higher = fewer missed hosts)
SCAN_TIMEOUT=0.5
# HTTP fingerprint timeout per service
SCAN_FP_TIMEOUT=3.0
# Parallel TCP probe workers (higher = faster scan)
SCAN_CONCURRENCY=100

# ── Kubernetes ─────────────────────────────────────────────────────────────────
# API server URL (e.g. https://192.168.1.100:6443 or https://host.docker.internal:6443)
KUBERNETES_URL=
# Service account or user bearer token (omit if API server is unauthenticated)
KUBERNETES_TOKEN=
# Set to false if the API server uses a self-signed certificate
KUBERNETES_VERIFY_SSL=true

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_URL=http://host.docker.internal:3000
# Grafana service account token (required for datasource/dashboard/alert counts)
GRAFANA_API_KEY=

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_URL=http://host.docker.internal:5000
# Bearer token if MLflow authentication is enabled
MLFLOW_TOKEN=

# ── Ports (optional overrides) ─────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=8080
