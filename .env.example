# ── Authentication ─────────────────────────────────────────────────────────────
# Set to false to disable auth (dev only)
AUTH_ENABLED=true

# MUST be changed in production — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-to-a-long-random-secret-in-production

# Token lifetime in minutes (default 8h)
AUTH_TOKEN_EXPIRE_MINUTES=480

# Bootstrap admin credentials — CHANGE IMMEDIATELY after first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=purpleclaw-admin

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Leave empty to use embedded SQLite (default)
# PostgreSQL example: postgresql://user:pass@host:5432/purpleclaw
DATABASE_URL=

# ── Integrations ───────────────────────────────────────────────────────────────
# Prometheus base URL (e.g. http://prometheus:9090)
PROMETHEUS_URL=

# Loki base URL (e.g. http://loki:3100)
LOKI_URL=
