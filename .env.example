# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-to-a-long-random-secret-in-production

# Token lifetime in minutes (default 8h)
AUTH_TOKEN_EXPIRE_MINUTES=480

# Bootstrap admin account — change immediately after first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * for dev or when behind a reverse proxy on the same host.
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Leave empty to use embedded SQLite.
# PostgreSQL: postgresql://user:pass@host:5432/purpleclaw
DATABASE_URL=

# ── Demo seed data ─────────────────────────────────────────────────────────────
# Set to false to skip demo assets/alerts/findings on first run.
# Only the admin user will be created when false.
SEED_DEMO_DATA=true

# ── Prometheus ─────────────────────────────────────────────────────────────────
# URL of your Prometheus instance.
# Homelab (host services, Docker deployed): http://host.docker.internal:9090
# Same Docker network: http://prometheus:9090
# Remote host: http://192.168.1.x:9090
PROMETHEUS_URL=http://host.docker.internal:9090
PROMETHEUS_ENV_ID=homelab
PROMETHEUS_TIMEOUT=3.0

# Additional Prometheus environments (optional):
# PROMETHEUS_URL_STAGING=http://staging-host:9090

# ── Loki ───────────────────────────────────────────────────────────────────────
# URL of your Loki instance.
LOKI_URL=http://host.docker.internal:3100
LOKI_ENV_ID=homelab
LOKI_TIMEOUT=3.0

# Comma-separated log source names expected in Loki (for gap detection).
# Leave empty to disable gap detection.
LOKI_EXPECTED_SOURCES=auth,syslog,kubernetes

# Additional Loki environments (optional):
# LOKI_URL_STAGING=http://staging-host:3100

# ── Ports (optional overrides) ─────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=8080
