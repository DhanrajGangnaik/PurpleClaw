HOST=0.0.0.0
PORT=8001

# Database — leave empty for embedded SQLite
# PostgreSQL: postgresql://user:pass@host:5432/purpleclaw
DATABASE_URL=

# Prometheus — set to your Prometheus URL
PROMETHEUS_URL=
PROMETHEUS_ENV_ID=default
PROMETHEUS_TIMEOUT=3.0

# Loki — set to your Loki URL
LOKI_URL=
LOKI_ENV_ID=default
LOKI_TIMEOUT=3.0
